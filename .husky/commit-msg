#!/bin/sh

# Block commits with AI-related mentions
if grep -iE "(claude|anthropic|chatgpt|openai|copilot|generated with|co-authored-by.*noreply@anthropic|co-authored-by.*openai)" "$1"; then
  echo ""
  echo "ERROR: Commit message contains AI-related mentions."
  echo "Please remove references to Claude, ChatGPT, Copilot, etc."
  echo ""
  exit 1
fi
